# Prefixo dos comandos do bot (ex: ! ou / ou .)
BOT_PREFIX=!

# Nome do bot (aparece nos logs)
BOT_NAME=WhatsApp Gateway

# Fuso horário (usado no comando !hora)
TIMEZONE=America/Sao_Paulo

# HTTP: envio por requisição (0 ou vazio = desligado)
HTTP_PORT=3000

# Opcional: Bearer ou X-API-Key; se vazio, /send não exige autenticação
API_SECRET=

# Responder automaticamente em mensagens privadas (ignora status/grupos/broadcast)
AUTO_REPLY=false
AUTO_REPLY_TEXT=Olá! Como posso ajudar?
